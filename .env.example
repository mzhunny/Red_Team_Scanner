# RedTeam Sentinel Environment Variables
# Copy this file to .env when runnable source code is added.

NODE_ENV=development
PORT=3000

# Optional AI enrichment key.
# Never commit a real API key to GitHub.
GEMINI_API_KEY=your_gemini_api_key_here

# Development-only simulation flag.
# Production should require real verification and keep failed targets unverified.
ALLOW_DEV_VERIFICATION_SIMULATION=false

# Example local persistence path.
DB_FILE_PATH=./db.json
